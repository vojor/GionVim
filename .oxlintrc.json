{
    "categories": {
        "correctness": "error",
        "perf": "warn",
        "suspicious": "warn",
        "pedantic": "off",
        "style": "off",
        "nursery": "off"
    },
    "env": {
        "node": true,
        "browser": true
    },
    "rules": {
        "curly": "error",
        "eqeqeq": "error",
        "indent": ["error", 4],
        "linebreak-style": ["error", "unix"],
        "no-alert": "error",
        "no-console": "warn",
        "no-unused-vars": "warn",
        "oxc/approx-constant": "warn",
        "prefer-const": "error",
        "quotes": ["error", "double"],
        "semi": "warn"
    },
    "overrides": [
        {
            "files": ["*.ts", "*.js"],
            "rules": {
                "no-unused-vars": "off",
                "@typescript-eslint/no-unused-vars": "error"
            }
        }
    ]
}
